{
  "name": "panoptrain",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:server": "pnpm --filter @panoptrain/server dev",
    "dev:client": "pnpm --filter @panoptrain/client dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "test": "pnpm -r --if-present test",
    "test:e2e": "pnpm --filter @panoptrain/e2e test:e2e",
    "download-gtfs": "pnpm --filter @panoptrain/server download-gtfs",
    "download-gtfs:lirr": "pnpm --filter @panoptrain/server download-gtfs:lirr"
  }
}
