{
  "name": "panoptrain",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:server": "pnpm --filter @panoptrain/server dev",
    "dev:client": "pnpm --filter @panoptrain/client dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "download-gtfs": "pnpm --filter @panoptrain/server download-gtfs"
  }
}
